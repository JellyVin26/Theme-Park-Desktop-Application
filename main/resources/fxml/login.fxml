<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/23.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.LoginController"
           style="-fx-background-color: #f6fbff;">

    <!-- This VBox is your login “card,” and will stay centered -->
    <VBox spacing="15"
          alignment="CENTER"
          maxWidth="350" maxHeight="350"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 10;
                 -fx-padding: 20;">
        <Label text="Sign in"
               style="-fx-font-size: 24px;
                      -fx-font-weight: bold;"/>
        <HBox spacing="5" alignment="CENTER">
            <Label text="or"/>
            <Hyperlink text="create an account"
                       onAction="#openSignup"/>
        </HBox>
        <TextField fx:id="emailField"
                   promptText="Email"
                   prefWidth="250"/>
        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       prefWidth="250"/>
        <HBox spacing="5" alignment="CENTER_LEFT">
            <CheckBox text="Remember me"/>
        </HBox>
        <Button text="SIGN IN"
                onAction="#handleLogin"
                prefWidth="250"
                style="-fx-background-color: #2a73f0;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;"/>
    </VBox>

</StackPane>
