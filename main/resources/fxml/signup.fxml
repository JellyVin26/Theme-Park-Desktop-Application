<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.SignupController"
           prefWidth="400" prefHeight="500" style="-fx-background-color: #f6fbff;">
    <children>
        <VBox spacing="10" alignment="CENTER" maxWidth="400" maxHeight="500"
              style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 20;">
            <Label text="Sign Up" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <HBox spacing="5">
                <Label text="or"/>
                <Hyperlink text="sign in" onAction="#openLogin"/>
            </HBox>
            <TextField fx:id="firstNameField" promptText="First Name" prefWidth="250"/>
            <TextField fx:id="lastNameField" promptText="Last Name" prefWidth="250"/>
            <TextField fx:id="emailField" promptText="Email" prefWidth="250"/>
            <PasswordField fx:id="passwordField" promptText="Password" prefWidth="250"/>
            <TextField fx:id="phoneField" promptText="Phone Number" prefWidth="250"/>
            <Button text="SIGN UP" onAction="#handleSignup" prefWidth="250"
                    style="-fx-background-color: #2a73f0; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </children>
</StackPane>
